<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container py-5">
        <h1 class="mb-4">
            <i class="fas fa-shopping-cart"></i> Shopping Cart
        </h1>

        <% if (cartItems.length === 0) { %>
            <div class="alert alert-info text-center py-5">
                <i class="fas fa-shopping-cart" style="font-size: 50px; margin-bottom: 20px;"></i>
                <h3>Your cart is empty</h3>
                <p class="text-muted">Add some books to get started</p>
                <a href="/shop/books" class="btn btn-primary">
                    <i class="fas fa-book"></i> Continue Shopping
                </a>
            </div>
        <% } else { %>
            <div class="row">
                <!-- Cart Items -->
                <div class="col-lg-8">
                    <div class="card">
                        <div class="card-body">
                            <% cartItems.forEach(item => { %>
                                <div class="cart-item d-flex gap-3">
                                    <!-- Product Image -->
                                    <div style="min-width: 100px;">
                                        <% if (item.cover_image) { %>
                                            <img src="<%= item.cover_image %>" alt="<%= item.title %>" class="img-fluid rounded" style="height: 100px; object-fit: cover;">
                                        <% } else { %>
                                            <div class="bg-light rounded d-flex align-items-center justify-content-center" style="height: 100px; width: 100px;">
                                                <i class="fas fa-book" style="font-size: 30px; color: #ccc;"></i>
                                            </div>
                                        <% } %>
                                    </div>

                                    <!-- Product Details -->
                                    <div class="flex-grow-1">
                                        <h5 class="mb-1"><%= item.title %></h5>
                                        <p class="text-muted small mb-2">by <%= item.author %></p>
                                        <h6 class="text-primary fw-bold">Rs. <%= parseFloat(item.price).toFixed(2) %></h6>
                                    </div>

                                    <!-- Quantity -->
                                    <div class="text-center">
                                        <label class="small">Quantity</label>
                                        <div class="d-flex gap-2 justify-content-center">
                                            <button class="btn btn-sm btn-outline-secondary" onclick="updateQuantity(<%= item.cartId %>, <%= item.quantity - 1 %>)">
                                                <i class="fas fa-minus"></i>
                                            </button>
                                            <span class="form-control form-control-sm text-center" style="width: 50px;"><%= item.quantity %></span>
                                            <button class="btn btn-sm btn-outline-secondary" onclick="updateQuantity(<%= item.cartId %>, <%= item.quantity + 1 %>)">
                                                <i class="fas fa-plus"></i>
                                            </button>
                                        </div>
                                    </div>

                                    <!-- Subtotal -->
                                    <div class="text-center">
                                        <label class="small">Subtotal</label>
                                        <h6 class="fw-bold">Rs. <%= parseFloat(item.subtotal).toFixed(2) %></h6>
                                    </div>

                                    <!-- Remove -->
                                    <div class="text-center">
                                        <button class="btn btn-sm btn-danger" onclick="removeFromCart(<%= item.cartId %>)">
                                            <i class="fas fa-trash"></i> Remove
                                        </button>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                </div>

                <!-- Order Summary -->
                <div class="col-lg-4">
                    <div class="card sticky-top" style="top: 20px;">
                        <div class="card-body">
                            <h5 class="card-title">Order Summary</h5>
                            <hr>

                            <div class="d-flex justify-content-between mb-2">
                                <span>Subtotal:</span>
                                <span>Rs. <%= totalPrice %></span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Shipping:</span>
                                <span>Rs. 0.00</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Tax:</span>
                                <span>Rs. 0.00</span>
                            </div>

                            <hr>
                            <div class="d-flex justify-content-between fw-bold mb-3">
                                <span>Total:</span>
                                <span class="text-primary">Rs. <%= totalPrice %></span>
                            </div>

                            <a href="/cart/checkout" class="btn btn-primary w-100 mb-2">
                                <i class="fas fa-credit-card"></i> Proceed to Checkout
                            </a>
                            <a href="/shop/books" class="btn btn-outline-secondary w-100">
                                <i class="fas fa-arrow-left"></i> Continue Shopping
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>
    </div>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function updateQuantity(cartId, newQuantity) {
            if (newQuantity < 1) {
                removeFromCart(cartId);
                return;
            }

            fetch('/cart/update', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    cartId: cartId,
                    quantity: newQuantity
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert(data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Failed to update cart');
            });
        }

        function removeFromCart(cartId) {
            if (confirm('Are you sure you want to remove this item?')) {
                fetch('/cart/remove', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        cartId: cartId
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert(data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Failed to remove item');
                });
            }
        }
    </script>
</body>
</html>
