<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navigation -->
    <%- include('partials/navbar') %>

    <!-- Hero Section -->
    <section class="hero-section bg-primary text-white py-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h1 class="display-4 fw-bold mb-4">Welcome to BookVerse</h1>
                    <p class="lead mb-4">Discover your next favorite book from our vast collection of fiction, non-fiction, and more.</p>
                    <a href="/shop/books" class="btn btn-light btn-lg">
                        <i class="fas fa-search"></i> Browse Books
                    </a>
                </div>
                <div class="col-md-6 text-center">
                    <i class="fas fa-books" style="font-size: 200px; opacity: 0.2;"></i>
                </div>
            </div>
        </div>
    </section>

    <!-- Featured Books -->
    <section class="py-5">
        <div class="container">
            <h2 class="text-center mb-5 fw-bold">Featured Books</h2>
            <div class="row g-4">
                <% books.forEach(book => { %>
                    <div class="col-md-3 col-sm-6">
                        <div class="card h-100 shadow-sm book-card">
                            <% if (book.cover_image) { %>
                                <img src="<%= book.cover_image %>" class="card-img-top" alt="<%= book.title %>" style="height: 250px; object-fit: cover;">
                            <% } else { %>
                                <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 250px;">
                                    <i class="fas fa-book" style="font-size: 60px; color: #ccc;"></i>
                                </div>
                            <% } %>
                            <div class="card-body">
                                <h5 class="card-title text-truncate" title="<%= book.title %>"><%= book.title %></h5>
                                <p class="card-text text-muted small"><%= book.author %></p>
                                <p class="card-text small">
                                    <span class="badge bg-secondary"><%= book.category %></span>
                                </p>
                                <h6 class="card-text fw-bold text-primary">Rs. <%= parseFloat(book.price).toFixed(2) %></h6>
                            </div>
                            <div class="card-footer bg-white border-top">
                                <a href="/shop/book/<%= book.id %>" class="btn btn-sm btn-outline-primary w-100">
                                    <i class="fas fa-eye"></i> View Details
                                </a>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
            <div class="text-center mt-5">
                <a href="/shop/books" class="btn btn-primary btn-lg">
                    <i class="fas fa-arrow-right"></i> View All Books
                </a>
            </div>
        </div>
    </section>

    <!-- Categories Section -->
    <section class="bg-light py-5">
        <div class="container">
            <h2 class="text-center mb-5 fw-bold">Browse by Category</h2>
            <div class="row g-3">
                <% categories.forEach(category => { %>
                    <div class="col-md-4">
                        <a href="/shop/books?category=<%= category.id %>" class="card category-card text-decoration-none h-100 shadow-sm">
                            <div class="card-body text-center py-5">
                                <i class="fas fa-layer-group" style="font-size: 40px; color: #007bff; margin-bottom: 15px;"></i>
                                <h5 class="card-title text-dark"><%= category.name %></h5>
                            </div>
                        </a>
                    </div>
                <% }); %>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <%- include('partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
