<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>
                <i class="fas fa-receipt"></i> Order Details
            </h1>
            <a href="/user/orders" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Back to Orders
            </a>
        </div>

        <div class="row">
            <!-- Order Information -->
            <div class="col-lg-8">
                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Order #<%= order.id %></h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4">
                                <h6 class="text-muted">Order Date</h6>
                                <p class="fw-bold"><%= new Date(order.created_at).toLocaleDateString() %></p>
                            </div>
                            <div class="col-md-4">
                                <h6 class="text-muted">Order Status</h6>
                                <p>
                                    <% if (order.status === 'Pending') { %>
                                        <span class="badge bg-warning">Pending</span>
                                    <% } else if (order.status === 'Processing') { %>
                                        <span class="badge bg-info">Processing</span>
                                    <% } else if (order.status === 'Shipped') { %>
                                        <span class="badge bg-primary">Shipped</span>
                                    <% } else if (order.status === 'Delivered') { %>
                                        <span class="badge bg-success">Delivered</span>
                                    <% } else if (order.status === 'Cancelled') { %>
                                        <span class="badge bg-danger">Cancelled</span>
                                    <% } %>
                                </p>
                            </div>
                            <div class="col-md-4">
                                <h6 class="text-muted">Total Amount</h6>
                                <p class="fw-bold text-primary">Rs. <%= parseFloat(order.total_amount).toFixed(2) %></p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">Shipping Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <h6 class="text-muted">Address</h6>
                                <p>
                                    <%= order.shipping_address %><br>
                                    <%= order.city %>, <%= order.postal_code %><br>
                                    Phone: <%= order.phone_number %>
                                </p>
                            </div>
                            <div class="col-md-6">
                                <h6 class="text-muted">Payment Method</h6>
                                <p>
                                    <% if (order.payment_method === 'cod') { %>
                                        Cash on Delivery
                                    <% } else if (order.payment_method === 'card') { %>
                                        Credit/Debit Card
                                    <% } %>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">Order Items</h5>
                    </div>
                    <div class="card-body">
                        <% if (items && items.length > 0) { %>
                            <% items.forEach(item => { %>
                                <div class="d-flex gap-3 pb-3 mb-3 border-bottom">
                                    <% if (item.cover_image) { %>
                                        <img src="<%= item.cover_image %>" alt="<%= item.title %>" style="width: 80px; height: 110px; object-fit: cover; border-radius: 4px;">
                                    <% } else { %>
                                        <div class="bg-light d-flex align-items-center justify-content-center" style="width: 80px; height: 110px; border-radius: 4px;">
                                            <i class="fas fa-book" style="font-size: 30px; color: #ccc;"></i>
                                        </div>
                                    <% } %>
                                    <div class="flex-grow-1">
                                        <h6 class="mb-1"><%= item.title %></h6>
                                        <p class="text-muted small mb-2">by <%= item.author %></p>
                                        <div class="d-flex justify-content-between">
                                            <span>Quantity: <strong><%= item.quantity %></strong></span>
                                            <span>Price: <strong>Rs. <%= parseFloat(item.price).toFixed(2) %></strong></span>
                                        </div>
                                    </div>
                                    <div class="text-end">
                                        <h6 class="text-primary">Rs. <%= (parseFloat(item.price) * item.quantity).toFixed(2) %></h6>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p class="text-muted text-center py-3">No items in this order</p>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Order Summary Sidebar -->
            <div class="col-lg-4">
                <div class="card sticky-top" style="top: 20px;">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">Summary</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal:</span>
                            <span>Rs. <%= parseFloat(order.total_amount).toFixed(2) %></span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Shipping:</span>
                            <span>Rs. 0.00</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span>Tax:</span>
                            <span>Rs. 0.00</span>
                        </div>

                        <hr>

                        <div class="d-flex justify-content-between fw-bold mb-4">
                            <span>Total:</span>
                            <span class="text-primary" style="font-size: 18px;">Rs. <%= parseFloat(order.total_amount).toFixed(2) %></span>
                        </div>

                        <div class="alert alert-info" role="alert">
                            <h6 class="alert-heading">Order Status</h6>
                            <% if (order.status === 'Pending') { %>
                                <p class="mb-0">Your order is being processed. You'll be notified once it's shipped.</p>
                            <% } else if (order.status === 'Processing') { %>
                                <p class="mb-0">Your order is being prepared for shipment.</p>
                            <% } else if (order.status === 'Shipped') { %>
                                <p class="mb-0">Your order is on its way! Track your shipment for more details.</p>
                            <% } else if (order.status === 'Delivered') { %>
                                <p class="mb-0">Your order has been delivered. Thank you for your purchase!</p>
                            <% } else if (order.status === 'Cancelled') { %>
                                <p class="mb-0">This order has been cancelled. For assistance, contact support.</p>
                            <% } %>
                        </div>

                        <a href="/user/orders" class="btn btn-primary w-100">
                            <i class="fas fa-list"></i> View All Orders
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
